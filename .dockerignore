# Version control
.git
.gitignore
.gitattributes

# Dependencies (installed inside the image during build)
/vendor
/node_modules

# Build artifacts (generated inside the image)
/public/build
/public/hot
/public/storage

# Local environment & secrets — never ship these into an image
.env
.env.*
!.env.example

# Runtime / writable state
/storage/app/*
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/logs/*
/storage/debugbar
/storage/pail

# Compiled package-discovery / service caches — must be regenerated inside the
# image. If shipped, they can reference dev-only packages (e.g. debugbar) that
# are absent from the --no-dev build and break artisan at build time.
/bootstrap/cache/*.php

# Tooling, CI, docs, and compose files (not needed at runtime)
# NOTE: /docker is intentionally NOT ignored — the dev stage copies
# docker/php/entrypoint-dev.sh and the web image copies docker/nginx/default.conf.
/.github
/tests
docker-compose*.yml
DEPLOYMENT.md
README.md
phpunit.xml
/database_model

# Editor / OS noise
.idea
.vscode
.DS_Store
*.log
