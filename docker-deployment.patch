diff --git a/.github/workflows/deploy-on-release.yml b/.github/workflows/deploy-on-release.yml
new file mode 100644
index 0000000..adcf99e
--- /dev/null
+++ b/.github/workflows/deploy-on-release.yml
@@ -0,0 +1,70 @@
+name: Deploy on release
+
+on:
+  release:
+    types: [published]
+
+permissions:
+  contents: read
+  packages: write
+
+jobs:
+  build-and-push:
+    runs-on: ubuntu-latest
+    steps:
+      - name: Checkout
+        uses: actions/checkout@v4
+
+      - name: Set up QEMU
+        uses: docker/setup-qemu-action@v2
+
+      - name: Set up Docker Buildx
+        uses: docker/setup-buildx-action@v2
+
+      - name: Log in to GHCR
+        uses: docker/login-action@v2
+        with:
+          registry: ghcr.io
+          username: ${{ github.actor }}
+          password: ${{ secrets.GITHUB_TOKEN }}
+
+      - name: Build and push app image
+        uses: docker/build-push-action@v4
+        with:
+          context: .
+          file: docker/php/Dockerfile
+          target: prod
+          push: true
+          tags: |
+            ghcr.io/${{ github.repository_owner }}/proyex-app:release-${{ github.event.release.tag_name }}
+            ghcr.io/${{ github.repository_owner }}/proyex-app:latest
+
+      - name: Build and push web image
+        uses: docker/build-push-action@v4
+        with:
+          context: ./docker/nginx
+          push: true
+          tags: |
+            ghcr.io/${{ github.repository_owner }}/proyex-web:release-${{ github.event.release.tag_name }}
+            ghcr.io/${{ github.repository_owner }}/proyex-web:latest
+
+  deploy:
+    needs: build-and-push
+    runs-on: ubuntu-latest
+    steps:
+      - name: Wait for registry
+        run: sleep 5
+
+      - name: Deploy to droplet via SSH
+        uses: appleboy/ssh-action@v0.1.7
+        with:
+          host: ${{ secrets.DROPLET_HOST }}
+          username: ${{ secrets.DROPLET_USER }}
+          port: ${{ secrets.DROPLET_SSH_PORT }}
+          key: ${{ secrets.DROPLET_SSH_KEY }}
+          script: |
+            set -e
+            cd /home/${{ secrets.DROPLET_USER }}/app || exit 0
+            docker compose pull || true
+            docker compose up -d --remove-orphans
+            docker image prune -f || true
